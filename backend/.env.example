DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=church_system

JWT_SECRET=change-this-before-production
PORT=3000
APP_NAME=choice-networks-church-saas
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,https://localhost,https://church.choicenetworks.co.ke

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://church.choicenetworks.co.ke/api/payments/mpesa/webhook

# Optional mobile B2C withdrawals.
# Tenant B2C credentials are saved per church from the platform M-Pesa credentials form.
# MPESA_B2C_CALLBACK_BASE_URL builds the shared backend callback URLs.
# MPESA_B2C_SECURITY_CREDENTIAL is Daraja's encrypted security credential; paste it per church, never store an operator PIN.
MPESA_B2C_ENV=sandbox
MPESA_B2C_COMMAND_ID=BusinessPayment
MPESA_B2C_CALLBACK_BASE_URL=https://church.christglory.co.ke
MPESA_B2C_RESULT_URL=https://church.christglory.co.ke/api/mobile/b2c/withdrawals/callback/result
MPESA_B2C_TIMEOUT_URL=https://church.christglory.co.ke/api/mobile/b2c/withdrawals/callback/timeout
MPESA_B2C_MIN_AMOUNT=1
MPESA_B2C_MAX_AMOUNT=150000

ADVANTA_PARTNER_ID=
ADVANTA_API_KEY=
ADVANTA_SHORTCODE=
ADVANTA_BASE_URL=https://quicksms.advantasms.com
SYSTEM_SMS_PARTNER_ID=
SYSTEM_SMS_API_KEY=
SYSTEM_SMS_SHORTCODE=
SYSTEM_SMS_BASE_URL=https://quicksms.advantasms.com

# Optional Android mobile app push notifications.
# Leave blank to run in log-only/no-op mode.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
